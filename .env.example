# ---------------------------------------------------------------------------
# Moodify — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Both variables are OPTIONAL.
# Without them the app runs fine in standalone/offline mode —
# posts are stored in localStorage only (not shared across users).
# ---------------------------------------------------------------------------

# JSONBin.io — free shared storage for the community feed
# Sign up at https://jsonbin.io, create a bin with {"posts":[]}, then copy:
VITE_JSONBIN_BIN_ID=your_bin_id_here
VITE_JSONBIN_API_KEY=your_master_key_here
